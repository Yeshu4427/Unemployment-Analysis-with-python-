import pandas as pd
import matplotlib.pyplot as plt


data = {
    'Year': [2018, 2019, 2020, 2021, 2022, 2023],
    'Unemployment_Rate': [5.3, 5.0, 8.5, 7.2, 6.1, 5.4]
}


df = pd.DataFrame(data)


print("Unemployment Data:")
print(df)


print("\nAverage Unemployment Rate:", df['Unemployment_Rate'].mean())



plt.plot(df['Year'], df['Unemployment_Rate'], marker='o')
plt.title("Unemployment Rate Trend")
plt.xlabel("Year")
plt.ylabel("Unemployment Rate (%)")
plt.grid(True)
plt.show()
